brew-backup() {
  command brew bundle dump --force --file="$HOME/.config/brew/Brewfile"
}

brew() {
  command brew "$@"
  local brew_status=$?

  case "$1" in
    install|remove|uninstall)
      if [ $brew_status -eq 0 ]; then
        brew-backup || return $?
      fi
      ;;
  esac

  return $brew_status
}

unalias dotsync 2>/dev/null
dotsync() {
  brew-backup &&
    chezmoi re-add &&
    chezmoi update &&
    mise install &&
    brew bundle install --file="$HOME/.config/brew/Brewfile"
}

# ALIAS
alias "ls"="eza"
alias "l"="eza -l --classify=auto --group-directories-first"
alias "colortest"="~/.config/colortest"

alias gadd="
git ls-files -m -o --exclude-standard |
  fzf -m --preview 'git diff --color=always {} 2>/dev/null || cat {}' |
  xargs git add
"

alias gunstage="
git diff --cached --name-only |
  fzf -m --preview 'git diff --cached --color=always {} 2>/dev/null || cat {}' |
  xargs git restore --staged
"

# FUNCS
proj() {
  local dir
  dir=$(zoxide query -l | fzf --preview 'eza -l --color=always {}') || return
  pushd "$dir" > /dev/null
  nvim .
  popd > /dev/null
}

