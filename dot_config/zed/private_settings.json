{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "right"
  },
  "show_edit_predictions": false,
  "relative_line_numbers": "enabled",
  "icon_theme": "One Dark",
  "theme": "One Dark",
  "format_on_save": "on",
  "formatter": "language_server",
  "tab_size": 2,
  "buffer_font_family": "Monaspace Argon Var",
  "buffer_font_features": {
    "calt": false
  },
  "confirm_quit": true,
  "show_whitespaces": "all",
  "terminal": {
    "font_family": "Monaspace Argon Var"
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    }
  },
  "vim_mode": false,
  "tabs": {
    "file_icons": true
  },
  "preview_tabs": {
    "enabled": false
  }
}
